POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=daily_logos_dev
DB_PORT=5433
DATABASE_URL=ecto://postgres:postgres@localhost:5433/daily_logos_dev
POOL_SIZE=10

# Google AdSense Configuration
# Fill these in to enable ad slots (copy to .env, not committed to git)

# Your Google AdSense Client ID
# Get it from: https://adsense.google.com/
# → Settings → Account information → Publisher ID
# Example: ca-pub-1234567890123456
GOOGLE_ADSENSE_CLIENT_ID=ca-pub-YOUR_CLIENT_ID

# Google AdSense Unit ID for footer ad slot
# Get it from: https://adsense.google.com/
# → Ads → Ad units → Create or view ad units
# Example: 1234567890
GOOGLE_ADSENSE_UNIT_FOOTER=