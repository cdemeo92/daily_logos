{
  "name": "Daily Logos",
  "dockerComposeFile": [
    "../docker-compose.yml",
    "docker-compose.yml"
  ],
  "service": "app",
  "workspaceFolder": "/workspaces/daily_logos",
  "forwardPorts": [4000],
  "portsAttributes": {
    "4000": {
      "label": "Phoenix",
      "onAutoForward": "openBrowser"
    }
  },
  "postCreateCommand": "mix deps.get && mix ecto.setup && mix assets.setup",
  "customizations": {
    "vscode": {
      "extensions": [
        "jakebecker.elixir-ls",
        "phoenixframework.phoenix",
        "bradlc.vscode-tailwindcss"
      ]
    }
  },
  "remoteUser": "root"
}
